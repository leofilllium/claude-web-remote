# Server port
PORT=3333

# Base directory to scan for projects (absolute path)
PROJECTS_DIR=/home/user

# Path to claude CLI binary (if not in PATH)
CLAUDE_BIN=claude

# ── Local Model Configuration (Ollama) ───────────────
# To use Claude Code with local models (completely free, no subscription):
# 1. Start your local Ollama server (e.g. `ollama serve`)
# 2. Pull a model (e.g. `ollama pull qwen3.5:9b`)
# 3. Set the variables below:

CLAUDE_MODEL=ollama:qwen3.5:9b
ANTHROPIC_BASE_URL=http://localhost:11434
ANTHROPIC_API_KEY=ollama  # Dummy key required by Claude CLI

# (If using standard Anthropic models, comment out the 3 lines above)

# Tunnel basic auth (strongly recommended when using `npm run tunnel`)
TUNNEL_AUTH_USER=admin
TUNNEL_AUTH_PASS=changeme
