# Server port
PORT=3333

# Base directory to scan for projects (absolute path)
PROJECTS_DIR=/home/user

# Path to claude CLI binary (if not in PATH)
CLAUDE_BIN=claude

# To use Claude Code completely free with a local Ollama model:
# (Requires Ollama to be installed and running on your machine)
CLAUDE_BIN=ollama launch claude --yes --model qwen3.5:9b --

# (If using standard Anthropic models, comment out the 3 lines above)

# Tunnel basic auth (strongly recommended when using `npm run tunnel`)
TUNNEL_AUTH_USER=admin
TUNNEL_AUTH_PASS=changeme
