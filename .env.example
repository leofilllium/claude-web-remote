# Server port
PORT=3333

# Base directory to scan for projects (absolute path)
PROJECTS_DIR=/home/user

# Path to claude CLI binary (if not in PATH)
CLAUDE_BIN=claude

# ── Qwen Code Configuration (Free Open-Source Alternative) ────────
# If you prefer not to use Anthropic's CLI at all, you can use Qwen Code,
# an open-source clone of Claude Code optimized for local Ollama usage.
# 1. Install globally: `npm install -g @qwen-code/qwen-code@latest`
# 2. Run your local model: `ollama run qwen2.5-coder:7b`
# 3. Uncomment these lines:
# CLAUDE_BIN=qwen
# QWEN_BASE_URL=http://localhost:11434/v1
# QWEN_API_KEY=ollama

# ── Claude Code Configuration (via Ollama Wrapper) ────────
# To use the official Claude Code with a local Ollama model:
# (Requires Ollama to be installed and running on your machine)
CLAUDE_BIN=ollama launch claude --yes --model qwen3.5:9b --

# (If using standard Anthropic models, comment out the 3 lines above)

# Tunnel basic auth (strongly recommended when using `npm run tunnel`)
TUNNEL_AUTH_USER=admin
TUNNEL_AUTH_PASS=changeme
