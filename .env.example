# Server port
PORT=3333

# Base directory to scan for projects (absolute path)
PROJECTS_DIR=/home/user

# CLI command to run (supports full command with arguments)
# Examples:
#   CLAUDE_BIN=claude
#   CLAUDE_BIN=ollama launch claude --model qwen3.5:9b
#   CLAUDE_BIN=/usr/local/bin/claude
CLAUDE_BIN=claude

# Tunnel basic auth (strongly recommended when using `npm run tunnel`)
TUNNEL_AUTH_USER=admin
TUNNEL_AUTH_PASS=changeme
